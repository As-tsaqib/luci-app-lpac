From: As Tsaqib <0xfiqks@gmail.com>
Date: Mon, 20 Jul 2026 00:00:00 +0800
Subject: [PATCH] driver: curl: verify provider TLS certificates

Network-facing LPA operations carry activation credentials and provider
notifications. Do not disable libcurl's certificate-chain or hostname checks.
The OpenWrt libcurl package is configured with the system CA bundle at
/etc/ssl/certs/ca-certificates.crt, which the package dependency installs.
---
 driver/http/curl.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

--- a/driver/http/curl.c
+++ b/driver/http/curl.c
@@ -87,8 +87,8 @@ static int http_interface_transmit(struc
     libcurl._curl_easy_setopt(curl, CURLOPT_URL, url);
     libcurl._curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, http_trans_write_callback);
     libcurl._curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&responseData);
-    libcurl._curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 0L);
-    libcurl._curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 0L);
+    libcurl._curl_easy_setopt(curl, CURLOPT_SSL_VERIFYPEER, 1L);
+    libcurl._curl_easy_setopt(curl, CURLOPT_SSL_VERIFYHOST, 2L);
     for (int i = 0; h[i] != NULL; i++) {
         nheaders = libcurl._curl_slist_append(headers, h[i]);
         if (nheaders == NULL) {
